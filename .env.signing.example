# Copy to .env.signing locally — NEVER commit .env.signing or real values to git.
# Use the same names in Codemagic workflow environment or Code signing identities UI.

# --- Apple (Codemagic integration preferred over raw secrets) ---
# APP_STORE_CONNECT_INTEGRATION=codemagic-shutterbid
APPLE_TEAM_ID=9K4K434DW8

# Optional if not using Codemagic automatic signing:
# APPLE_DISTRIBUTION_CERTIFICATE_BASE64=
# APPLE_PROVISIONING_PROFILE_BASE64=
# APP_STORE_CONNECT_KEY_IDENTIFIER=
# APP_STORE_CONNECT_ISSUER_ID=
# APP_STORE_CONNECT_PRIVATE_KEY=

# --- FishCrew Android ---
FISHCREW_KEYSTORE_PATH=/absolute/path/to/fishcrew-upload-key-final.jks
FISHCREW_KEYSTORE_PASSWORD=
FISHCREW_KEY_ALIAS=fishcrew-upload
FISHCREW_KEY_PASSWORD=

# Codemagic Android signing reference name (UI upload):
# FISHCREW_CODEMAGIC_KEYSTORE_REF=fishcrew-upload-key

# --- ShutterBid Android ---
SHUTTERBID_KEYSTORE_PATH=/absolute/path/to/shutterbid-upload-key-final.jks
SHUTTERBID_KEYSTORE_PASSWORD=
SHUTTERBID_KEY_ALIAS=shutterbid-upload
SHUTTERBID_KEY_PASSWORD=

# Codemagic Android signing reference name:
# SHUTTERBID_CODEMAGIC_KEYSTORE_REF=shutterbid-upload-key

# --- CurbCue (FairShare) hybrid Capacitor ---
CURBCUE_BUNDLE_ID=com.chrissims.fairshare
CURBCUE_PACKAGE_NAME=com.chrissims.fairshare
# CURBCUE_APP_STORE_APPLE_ID=TBD
# CURBCUE_ANDROID_KEYSTORE_REFERENCE=curbcue-upload-key
# CURBCUE_SERVER_URL=https://fairshare-v03-20260624.netlify.app

# --- MotoCrew hybrid Capacitor ---
MOTOCREW_BUNDLE_ID=com.chrissims.throttlelink
MOTOCREW_PACKAGE_NAME=com.chrissims.throttlelink
# MOTOCREW_APP_STORE_APPLE_ID=TBD
# MOTOCREW_ANDROID_KEYSTORE_REFERENCE=motocrew-upload-key
# MOTOCREW_SERVER_URL=https://motocrewz.netlify.app

# --- CoachCore hybrid Capacitor ---
COACHCORE_BUNDLE_ID=com.chrissims.coachcore
COACHCORE_PACKAGE_NAME=com.chrissims.coachcore
# COACHCORE_APP_STORE_APPLE_ID=TBD
# COACHCORE_ANDROID_KEYSTORE_REFERENCE=coachcore-upload-key
# COACHCORE_SERVER_URL=https://coachcore7.netlify.app/app

# --- Sermon Studio hybrid Capacitor ---
SERMON_STUDIO_BUNDLE_ID=com.chrissims.sermonstudio
SERMON_STUDIO_PACKAGE_NAME=com.chrissims.sermonstudio
# SERMON_STUDIO_APP_STORE_APPLE_ID=TBD
# SERMON_STUDIO_ANDROID_KEYSTORE_REFERENCE=sermon-studio-upload-key
# SERMON_STUDIO_SERVER_URL=https://sermon-studio-beta.netlify.app

# --- ShutterBid Capacitor remote shell (confirm production URL) ---
SHUTTERBID_SERVER_URL=https://YOUR-VERCEL-PROD-URL.example

# --- Gradle / Android SDK (local builds only) ---
# ANDROID_HOME=/Users/you/Library/Android/sdk
# JAVA_HOME=/path/to/jdk-21
